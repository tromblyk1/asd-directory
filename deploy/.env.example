# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — credentials never get committed.

# From Hostinger hPanel:
#   Websites → Manage → Advanced → SSH Access
#   (SSH must be ENABLED on that page first — toggle on the right side)

# IP shown on the SSH Access page (e.g. 82.29.157.57)
SFTP_HOST=

# IMPORTANT: Hostinger uses a NON-STANDARD high-numbered SSH port (e.g. 65002),
# NOT the default 22. Get the exact number from the SSH Access page.
SFTP_PORT=

# Username shown on the SSH Access page (e.g. u123456789 — no domain suffix)
SFTP_USER=

# Your SSH password. Set/reset it on the SSH Access page if needed.
SFTP_PASS=

# Absolute path to your web root. Hostinger TRAP: there are usually TWO
# `public_html` folders on the server, and only one is the live web root:
#   /home/<user>/public_html/                                       ← legacy, NOT served
#   /home/<user>/domains/floridaautismservices.com/public_html/     ← THIS is the live root
# Verify via hPanel File Manager (look for the DO_NOT_UPLOAD_HERE marker —
# the LIVE folder is the sibling of that marker file under your domain).
# Example: /home/u123456789/domains/floridaautismservices.com/public_html/
REMOTE_PATH=
